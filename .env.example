# GitHub OAuth App
# Register an app at https://github.com/settings/developers to get a Client ID
GITHUB_COPILOT_CLIENT_ID=your_github_oauth_client_id_here

# GitHub Copilot API Endpoints (defaults shown — change only if needed)
GITHUB_COPILOT_DEVICE_CODE_URL=https://github.com/login/device/code
GITHUB_COPILOT_ACCESS_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_COPILOT_LLM_TOKEN_URL=https://api.github.com/copilot_internal/v2/token
GITHUB_COPILOT_LLM_CHAT_URL=https://api.githubcopilot.com/chat/completions

# Model Settings
GITHUB_COPILOT_MODEL=gpt-4o
GITHUB_COPILOT_MAX_TOKENS=4096
GITHUB_COPILOT_TEMPERATURE=0.1

# Corporate / Proxy Network (optional — only needed behind a corporate proxy)
# SSL_CERT_FILE=certs/your-ca-bundle.pem
# HTTP_PROXY=http://username:password@proxy-host:port
# HTTPS_PROXY=http://username:password@proxy-host:port
